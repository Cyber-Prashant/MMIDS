<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.BIND_DEVICE_ADMIN"/>

    <application
        android:name=".MMIDSApp"
        android:label="MMID"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.MMIDS"
        android:enableOnBackInvokedCallback="true">

        <!-- Main Activity — NO launcher intent -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|density|uiMode"
            android:resizeableActivity="true"/>

        <!-- Hidden launcher aliases — only one enabled at a time -->
        <activity-alias android:name=".AliasSettings"
            android:targetActivity=".MainActivity"
            android:enabled="true" android:exported="true"
            android:label="System Settings" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasSignal"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="Signal Monitor" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasTool"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="Device Tools" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasStats"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="Usage Stats" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasBattery"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="Battery Manager" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasNetwork"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="Network Info" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasClock"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="Clock Service" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias android:name=".AliasFiles"
            android:targetActivity=".MainActivity"
            android:enabled="false" android:exported="true"
            android:label="File Manager" android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <!-- Intruder Alert Activity -->
        <activity
            android:name=".ui.screens.IntruderAlertActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.MMIDS"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"/>

        <!-- Receivers -->
        <receiver android:name=".receivers.VolumeReceiver" android:exported="false">
            <intent-filter>
                <action android:name="android.media.VOLUME_CHANGED_ACTION"/>
            </intent-filter>
        </receiver>

        <receiver android:name=".receivers.UnlockReceiver" android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.USER_PRESENT"/>
            </intent-filter>
        </receiver>

        <receiver android:name=".receivers.DialerReceiver" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.NEW_OUTGOING_CALL"/>
            </intent-filter>
        </receiver>

        <receiver android:name=".receivers.ShutdownReceiver" android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.ACTION_SHUTDOWN"/>
                <action android:name="android.intent.action.REBOOT"/>
                <action android:name="android.intent.action.QUICKBOOT_POWEROFF"/>
            </intent-filter>
        </receiver>

        <!-- Auto-start on device boot -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:exported="true"
            android:enabled="true"
            android:directBootAware="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </receiver>

        <receiver
            android:name=".admin.MMIDSDeviceAdmin"
            android:exported="true"
            android:label="System Service Admin"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies"/>
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED"/>
            </intent-filter>
        </receiver>

        <!-- Foreground Service -->
        <service
            android:name=".services.MonitoringService"
            android:foregroundServiceType="dataSync"
            android:exported="false"/>

    </application>
</manifest>
